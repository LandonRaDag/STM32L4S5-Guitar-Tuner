#define DEBOUNCE_DELAY 50  // Debounce delay in milliseconds




void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
    if (GPIO_Pin == GPIO_PIN_13) {  // Blue button on PC13
        uint32_t current_time = HAL_GetTick();  // Get the current system time

        // Debounce logic: Ignore presses within 50 ms
        if ((current_time - last_press_time) < DEBOUNCE_DELAY) {
            return;  // Ignore bouncing
        }

        last_press_time = current_time;  // Update the last press time

        // Increment press count
        press_count++;

        // Debug output
