//        HAL_UART_Transmit(&huart1, (uint8_t *)debug_msg, strlen(debug_msg), HAL_MAX_DELAY);
    }
}





void switchMode() {
    current_mode = (current_mode + 1) % 2;  // Cycle between 0, 1 (Ear Tuning, Microphone)

    switch (current_mode) {
        case MODE_EAR_TUNING:
            HAL_UART_Transmit(&huart1, (uint8_t *)"Mode: Ear Tuning\r\n", 19, HAL_MAX_DELAY);
            break;
        case MODE_MICROPHONE:
            HAL_UART_Transmit(&huart1, (uint8_t *)"Mode: Microphone Tuning\r\n", 26, HAL_MAX_DELAY);
            break;

    }
}




void changeNote() {
    current_note_index = (current_note_index + 1) % 6;  // Cycle through 0 to 5 (E, A, D, G, B, e)

    char note_msg[30];
    sprintf(note_msg, "Playing Note: %s\r\n", guitar_notes[current_note_index]);
    HAL_UART_Transmit(&huart1, (uint8_t *)note_msg, strlen(note_msg), HAL_MAX_DELAY);
}




void evaluateFrequency(float receivedFrequency) {


    float targetFrequency = 0.0f;
    const char* targetNote = "Unknown";
    char result[50];
    int isValid = 0;  // Flag to indicate if a valid targetFrequency is found

    // Determine the target frequency
    for (int i = 0; i < sizeof(referenceNotes) / sizeof(ReferenceNote); i++) {
        if (receivedFrequency >= referenceNotes[i].frequency - 5.0 &&
            receivedFrequency <= referenceNotes[i].frequency + 5.0) {
            targetFrequency = referenceNotes[i].frequency;
            targetNote = referenceNotes[i].note;
            current_note_index = i;  // Update current note index for consistency
            isValid = 1;
            break;
        }
    }

    // If no valid target frequency is found
    if (!isValid) {
        sprintf(result, "Frequency %.2f Hz is too far from any target!\r\n", receivedFrequency);
        HAL_UART_Transmit(&huart1, (uint8_t *)result, strlen(result), HAL_MAX_DELAY);
        return;
    }

    // Calculate the difference between received and target frequencies
    float difference = receivedFrequency - targetFrequency;

    // Logic to determine the tuning status
    if (difference >= -1.0 && difference <= 1.0) {
        // Perfectly In Tune (±1 Hz)
        sprintf(result, ">%s< (%.2f Hz)  In Tune\r\n ", targetNote, receivedFrequency);
    } else if (difference > 1.0 && difference <= 2.0) {
        // Slightly Sharp (1 Hz < Difference <= 2 Hz)
        sprintf(result, "%s< (%.2f Hz)  Tune Down\r\n ", targetNote, receivedFrequency);
    } else if (difference < -1.0 && difference >= -2.0) {
        // Slightly Flat (-2 Hz <= Difference < -1 Hz)
        sprintf(result, "%s> (%.2f Hz)  Tune Up\r\n ", targetNote, receivedFrequency);
    } else if (difference > 2.0 && difference <= 5.0) {
        // Out of Tune (2 Hz < Difference <= 5 Hz, Sharp)
        sprintf(result, "%s<< (%.2f Hz)  Tune Down\r\n ", targetNote, receivedFrequency);
    } else if (difference < -2.0 && difference >= -5.0) {
        // Out of Tune (-5 Hz <= Difference < -2 Hz, Flat)
        sprintf(result, "%s>> (%.2f Hz)  Tune Up\r\n ", targetNote, receivedFrequency);
    } else {
        // Ignore frequencies beyond ±5 Hz
        sprintf(result, "Frequency %.2f Hz is too far off target!\r\n", receivedFrequency);
    }

    // Send result via UART
    HAL_UART_Transmit(&huart1, (uint8_t *)result, strlen(result), HAL_MAX_DELAY);
}



